<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>{{ title }}</title>
<link rel="icon" type="image/x-icon" href="/static/r_logo.png">

<meta http-equiv="refresh" content="5">

<style>
body{
    font-family:Segoe UI;
    background:#f0f4f8;
    padding:15px;
}

/* NAVBAR */
.navbar{
    background:#1e293b;
    color:white;
    padding:10px;
    border-radius:8px;
    display:flex;
    justify-content:space-between;
}

.navbar a{
    color:white;
    text-decoration:none;
    margin-left:12px;
    font-size:14px;
}

/* SUMMARY BOX */
.summary{
    display:flex;
    gap:10px;
    margin-top:10px;
}

.box{
    background:white;
    padding:8px 12px;
    border-radius:6px;
    font-size:13px;
    box-shadow:0 1px 4px rgba(0,0,0,0.1);
}

/* TABLE */
table{
    width:100%;
    background:white;
    border-radius:8px;
    margin-top:15px;
    border-collapse:collapse;
    font-size:13px;
}

th, td{
    padding:8px;
    text-align:center;
}

th{
    background:#e2e8f0;
}

tr:nth-child(even){
    background:#f9fafb;
}

/* PAGINATION */
.pagination{
    margin-top:10px;
    text-align:center;
}

.pagination a{
    padding:6px 10px;
    background:#1e293b;
    color:white;
    margin:2px;
    text-decoration:none;
    border-radius:4px;
    font-size:12px;
}

/* TIME STYLES */
.active-time {
    color: #28a745;
    font-weight: bold;
}

.idle-time {
    color: #fd7e14;
    font-weight: bold;
}

/* EMPTY STATE */
.empty-state {
    color: #6c757d;
    font-style: italic;
}
</style>
</head>

<body>

<div class="navbar">
<div>{{ title }}</div>
<div>
<a href="/">Home</a>
<a href="/workstations">Workstations</a>
<a href="/logout">Logout</a>
</div>
</div>

<h3>System Overview</h3>

<div class="summary">
<div class="box">Total: {{ total_systems }}</div>
<div class="box">Online: {{ online_count }}</div>
<div class="box">Offline: {{ offline_count }}</div>
</div>

<table>
<thead>
<tr>
<th>WS Name</th>
<th>Status</th>
<th>Active Apps</th>
<th>Active Time Today</th>
<th>Idle Time Today</th>
</tr>
</thead>
<tbody>

{% for ws in workstations %}
<tr>
<td>{{ ws.name }}</td>

<td style="color:{{ ws.color }}">
    {{ ws.status }}
</td>

<!-- ACTIVE APPS -->
<td>
    {% if ws.active_apps %}
        {% for app in ws.active_apps %}
            {{ app }}{% if not loop.last %}, {% endif %}
        {% endfor %}
    {% else %}
        <span class="empty-state">No active apps</span>
    {% endif %}
</td>

<!-- ACTIVE TIME TODAY (Auto-converted to hours if >= 60 minutes) -->
<td>
    {% if ws.active_time_today > 0 %}
        <span class="active-time">
            {% if ws.active_time_today >= 60 %}
                {{ "%.1f"|format(ws.active_time_today / 60) }} hours
            {% else %}
                {{ "%.1f"|format(ws.active_time_today) }} minutes
            {% endif %}
        </span>
    {% else %}
        <span class="empty-state">0 minutes</span>
    {% endif %}
</td>

<!-- IDLE TIME TODAY (Auto-converted to hours if >= 60 minutes) -->
<td>
    {% if ws.idle_time_today > 0 %}
        <span class="idle-time">
            {% if ws.idle_time_today >= 60 %}
                {{ "%.1f"|format(ws.idle_time_today / 60) }} hours
            {% else %}
                {{ "%.1f"|format(ws.idle_time_today) }} minutes
            {% endif %}
        </span>
    {% else %}
        <span class="empty-state">0 minutes</span>
    {% endif %}
</td>

</tr>
{% endfor %}

</tbody>
</table>

<!-- PAGINATION -->
<div class="pagination">
{% if page > 1 %}
<a href="/?page={{ page-1 }}">Prev</a>
{% endif %}

<span>Page {{ page }}</span>

{% if has_next %}
<a href="/?page={{ page+1 }}">Next</a>
{% endif %}
</div>

</body>
</html>
